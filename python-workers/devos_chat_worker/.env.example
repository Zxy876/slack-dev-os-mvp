# Slack Dev OS — devos_chat_worker 环境变量配置
# 复制本文件为 .env 并填写实际值

# ── AsyncAIFlow 后端地址 ──────────────────────────────────────
ASYNCAIFLOW_URL=http://localhost:8080
DEVOS_WORKER_ID=devos-chat-worker-1
POLL_INTERVAL_S=2.0
HEARTBEAT_INTERVAL_S=10.0

# ── LLM 配置（选择其中一种）────────────────────────────────────
# OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                 # 可选，默认 api.openai.com
# OPENAI_MODEL=gpt-4o-mini

# ZhipuAI GLM（优先级更高）:
# GLM_API_KEY=your-glm-key
# GLM_BASE_URL=                    # 可选
# GLM_MODEL=glm-4

# Demo 模式（无 LLM key 时返回 stub 回复）:
# DEMO_MODE=true

# ── Slack 配置 ───────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
#
# slack_thread_id 格式示例：
#   "C1234567890/1234567890.123456"   → 回复到 thread
#   "C1234567890"                     → 发送到 channel
