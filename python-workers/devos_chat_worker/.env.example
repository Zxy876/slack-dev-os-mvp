# Slack Dev OS — devos_chat_worker 环境变量配置
# 复制本文件为 .env 并填写实际值
# !! 切勿将真实 key 提交到 git — .env 已加入 .gitignore !!

# ── AsyncAIFlow 后端地址 ──────────────────────────────────────
ASYNCAIFLOW_URL=http://localhost:8080
DEVOS_WORKER_ID=devos-chat-worker-local
POLL_INTERVAL_S=1
HEARTBEAT_INTERVAL_S=10.0

# ── 运行模式 ─────────────────────────────────────────────────
# DEMO_MODE=true  → stub 响应，不需要 LLM key（CI / 本地测试默认）
# DEMO_MODE=false → 使用真实 LLM（需设置 GLM_API_KEY 或 OPENAI_API_KEY）
DEMO_MODE=true

# ── LLM 配置（DEMO_MODE=false 时必须设置其中一个）──────────────
# LLM 优先级：DEMO_MODE=true（最高）> GLM_API_KEY > OPENAI_API_KEY
# DEMO_MODE=false 且两者均未设置时，worker 启动即 fail fast。

# ZhipuAI GLM（优先级高于 OpenAI）:
GLM_API_KEY=
# GLM_BASE_URL=                    # 可选
# GLM_MODEL=glm-4

# OpenAI:
OPENAI_API_KEY=
# OPENAI_BASE_URL=                 # 可选，兼容 API 地址（如 Azure / 本地代理）
# OPENAI_MODEL=gpt-4o-mini

# ── Slack 配置（可选）────────────────────────────────────────
# 未设置 SLACK_BOT_TOKEN 时，Slack 回写会跳过（仅打印 warning），
# Action 仍标记为 SUCCEEDED。
# REQUIRE_SLACK_POST=true 时，若无 token 则 worker 抛出 RuntimeError。
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
REQUIRE_SLACK_POST=false

# ── B-010-live-personal: Personal Slack Live Smoke ─────────
# 运行 scripts/run_slack_live_smoke.sh 时需要：
#
# DEVOS_LIVE_SLACK_THREAD_ID — 首选：channel_id/thread_ts 格式
#   例：DEVOS_LIVE_SLACK_THREAD_ID=C08XXXXXX/1714500000.123456
#   在 Slack 中右键某条消息 → "Copy link"，从 URL 末尾提取 p... 时间戳，
#   转换为 XXXXXXXXXX.XXXXXX 格式（在第 10 位插入"."）
#
# 或者仅发到频道顶层（不回复某条消息）：
#   DEVOS_LIVE_SLACK_CHANNEL=C08XXXXXX
#   Channel ID 在 Slack 频道详情页最底部可找到
#
DEVOS_LIVE_SLACK_THREAD_ID=
DEVOS_LIVE_SLACK_CHANNEL=

# ── 本地真实模式快速启动说明 ──────────────────────────────────
# 1. 复制本文件：cp .env.example .env
# 2. 设置 DEMO_MODE=false
# 3. 填写 GLM_API_KEY 或 OPENAI_API_KEY（选其一）
# 4. 可选：填写 SLACK_BOT_TOKEN + DEVOS_LIVE_SLACK_THREAD_ID
# 5. source .env && python worker.py
# 6. 验证：scripts/run_production_config_check.sh
# 7. Live smoke：scripts/run_slack_live_smoke.sh（需后端已启动）
#
# CI / E2E 脚本始终显式设置 DEMO_MODE=true 并 unset GLM/OpenAI key。
