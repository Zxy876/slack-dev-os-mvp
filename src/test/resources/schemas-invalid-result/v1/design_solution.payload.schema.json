{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "issue"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "issue": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "constraints": {
      "type": "string"
    }
  }
}
