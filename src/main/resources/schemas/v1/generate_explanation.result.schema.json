{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/generate_explanation.result.schema.json",
  "title": "generate_explanation result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "summary",
    "content",
    "worker",
    "model"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}