{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/load_code.payload.schema.json",
  "title": "load_code payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "file": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "maxFiles": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "maxCharsPerFile": {
      "type": "integer",
      "minimum": 200,
      "maximum": 20000
    }
  }
}
