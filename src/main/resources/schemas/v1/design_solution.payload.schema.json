{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/design_solution.payload.schema.json",
  "title": "design_solution payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "issue"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "issue": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
