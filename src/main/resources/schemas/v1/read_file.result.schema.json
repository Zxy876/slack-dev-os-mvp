{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/read_file.result.schema.json",
  "title": "read_file result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worker",
    "path",
    "content",
    "lineCount",
    "truncated",
    "fileSizeBytes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string"
    },
    "lineCount": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "fileSizeBytes": {
      "type": "integer",
      "minimum": 0
    }
  }
}