{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/review_patch.result.schema.json",
  "title": "review_patch result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worker",
    "model",
    "summary",
    "approved",
    "patch",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "approved": {
      "type": "boolean"
    },
    "patch": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "detail"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "major",
              "minor",
              "nit"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "content": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}