{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/review_code.result.schema.json",
  "title": "review_code result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "detail"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "major",
              "minor",
              "nit"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "line": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "suggestedFixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "patchHint"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "patchHint": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "content": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
