{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/build_context_pack.result.schema.json",
  "title": "build_context_pack result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worker",
    "issue",
    "summary",
    "sources"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "issue": {
      "type": "string",
      "minLength": 1
    },
    "engine": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "sourceCount": {
      "type": "integer",
      "minimum": 0
    },
    "retrievalCount": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file",
          "content",
          "lineCount",
          "truncated",
          "fileSizeBytes"
        ],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "content": {
            "type": "string"
          },
          "lineCount": {
            "type": "integer",
            "minimum": 0
          },
          "truncated": {
            "type": "boolean"
          },
          "fileSizeBytes": {
            "type": "integer",
            "minimum": 0
          },
          "excerpt": {
            "type": "string"
          }
        }
      }
    },
    "retrieval": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "score",
          "chunk"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "chunk": {
            "type": "string"
          },
          "lineNumber": {
            "type": "integer",
            "minimum": 1
          },
          "source": {
            "type": "string"
          }
        }
      }
    }
  }
}
