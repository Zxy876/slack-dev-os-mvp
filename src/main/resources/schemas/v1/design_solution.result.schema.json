{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/design_solution.result.schema.json",
  "title": "design_solution result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "proposedDesign": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "rationale"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "riskItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk",
          "impact",
          "mitigation"
        ],
        "properties": {
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "content": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
